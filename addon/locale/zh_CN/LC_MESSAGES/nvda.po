#. Translators: input help mode message for ObjPad toggle command.
#: addon/globalPlugins/objPad.py:39
msgid "Toggles ObjPad mode between normal, object nav and scan modes"
msgstr "简易导航切换（在正常模式、对象导航模式、网页模式和扫描模式之间切换）"

#. Translators: one of the object arrow modes.
#: addon/globalPlugins/objPad.py:47
msgid "Object nav mode"
msgstr "对象导航模式"

#. Translators: one of the object arrow modes.
#: addon/globalPlugins/objPad.py:51
msgid "Browse mode"
msgstr "浏览模式"

#. Translators: one of the object arrow modes.
#: addon/globalPlugins/objPad.py:55
msgid "Scan mode"
msgstr "扫描模式"

#. Translators: one of the object arrow modes.
#: addon/globalPlugins/objPad.py:59
msgid "Normal mode"
msgstr "正常模式"

#: addon/globalPlugins/objPad.py:85
msgid "Default (all elements)"
msgstr "默认（所有元素）"

#: addon/globalPlugins/objPad.py:86
msgid "Links"
msgstr "链接"

#: addon/globalPlugins/objPad.py:87
msgid "Form fields"
msgstr "表单字段"

#: addon/globalPlugins/objPad.py:88
msgid "Headings"
msgstr "标题"

#: addon/globalPlugins/objPad.py:89
msgid "Frames"
msgstr "框架"

#: addon/globalPlugins/objPad.py:90
msgid "Tables"
msgstr "表格"

#: addon/globalPlugins/objPad.py:91
msgid "Lists"
msgstr "列表"

#: addon/globalPlugins/objPad.py:92
msgid "Landmarks"
msgstr "路标"

#: addon/globalPlugins/objPad.py:93
msgid "Embedded objects"
msgstr "嵌入式对象"

#: addon/globalPlugins/objPad.py:94
msgid "Text paragraphs"
msgstr "文本段落"

#. Translators: a message when there is no next object when navigating
#: addon/globalPlugins/objPad.py:180
msgid "No next"
msgstr "没有下一项"

#. Translators: a message when there is no previous object when navigating
#: addon/globalPlugins/objPad.py:214
msgid "No previous"
msgstr "没有上一项"

#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: buildVars.py:21
msgid "ObjPad"
msgstr "简易导航器"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "Perform various object commands by pressing a single key, including navigation and more"
msgstr "一键执行各种对象快捷键，包括导航等"

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid "* Renamed \"web mode\" to \"browse mode\" as this mode will cover additional situations including browse mode in Word 365."
msgstr "* 将“web 模式”重命名为“浏览模式”，因为此模式将涵盖其他情况，包括 Word 365中的浏览模式。"


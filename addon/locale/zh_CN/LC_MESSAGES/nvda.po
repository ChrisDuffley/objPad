#. Translators: input help mode message for ObjPad toggle command.
#: addon\globalPlugins\objPad.py:40
msgid "Toggles ObjPad mode between normal, object nav and scan modes"
msgstr "简易导航切换（在正常模式、对象导航模式、网页模式和扫描模式之间切换）"

#. Translators: one of the object arrow modes.
#: addon\globalPlugins\objPad.py:48
msgid "Object nav mode"
msgstr "对象导航模式"

#. Translators: one of the object arrow modes.
#: addon\globalPlugins\objPad.py:52
msgid "Browse mode"
msgstr "浏览模式"

#. Translators: one of the object arrow modes.
#: addon\globalPlugins\objPad.py:56
msgid "Scan mode"
msgstr "扫描模式"

#. Translators: one of the object arrow modes.
#: addon\globalPlugins\objPad.py:60
msgid "Normal mode"
msgstr "正常模式"

#: addon\globalPlugins\objPad.py:86
msgid "default"
msgstr "默认"

#: addon\globalPlugins\objPad.py:87
msgid "headings"
msgstr "标题"

#: addon\globalPlugins\objPad.py:88
msgid "tables"
msgstr "表格"

#: addon\globalPlugins\objPad.py:89
msgid "links"
msgstr "链接"

#: addon\globalPlugins\objPad.py:90
msgid "form fields"
msgstr "表单字段"

#: addon\globalPlugins\objPad.py:91
msgid "lists"
msgstr "列表"

#: addon\globalPlugins\objPad.py:92
msgid "frames"
msgstr "框架"

#: addon\globalPlugins\objPad.py:94
msgid "landmarks"
msgstr "路标"

#: addon\globalPlugins\objPad.py:95
msgid "embedded objects"
msgstr "嵌入式对象"

#: addon\globalPlugins\objPad.py:96
msgid "text paragraphs"
msgstr "文本段落"

#. Translators: a message when there is no next object when navigating
#: addon\globalPlugins\objPad.py:203
msgid "No next"
msgstr "没有下一项"

#. Translators: a message when there is no previous object when navigating
#: addon\globalPlugins\objPad.py:244
msgid "No previous"
msgstr "没有上一项"

#. Add-on summary/title, usually the user visible name of the add-on
#. Translators: Summary/title for this add-on
#. to be shown on installation and add-on information found in add-on store
#: buildVars.py:21
msgid "ObjPad"
msgstr "简易导航器"

#. Add-on description
#. Translators: Long description to be shown for this add-on on add-on information from add-on store
#: buildVars.py:24
msgid "Perform various object commands by pressing a single key, including navigation and more"
msgstr "一键执行各种对象快捷键，包括导航等"

#. Brief changelog for this version
#. Translators: what's new content for the add-on version to be shown in the add-on store
#: buildVars.py:29
msgid "* Removed add-on changelog from add-on help (readme) file.\n"
"* If running NVDA 2026.2, add-on browse mode elements will be limited to default (all elements), headings, tables, links, form fields, and lists. On touchscreen computers, additional browse mode elements can be added via NVDA's browse mode settings.\n"
"* The \"default (all elements)\" mode in browse mode is now called \"default\" mode to match messaging from NVDA 2026.2's touch browse mode.\n"
"* Added graphics navigation to browse mode (NVDA 2025.3.3 and 2026.1)."
msgstr "* 已从插件帮助（自述文件）中移除插件更新日志。\n"
"* 如果运行 NVDA 2026.2，插件的浏览模式元素将仅限于默认（所有元素）、标题、表格、链接、表单字段和列表。可在具有触摸屏的计算机通过 NVDA 的浏览模式设置添加其他浏览模式元素。\n"
"* 浏览模式下的“默认（所有元素）”模式现已更名为“默认”模式，以匹配 NVDA 2026.2 触摸浏览模式中的表述。\n"
"* 为浏览模式添加了图形导航（NVDA 2025.3.3 和 2026.1）。"

